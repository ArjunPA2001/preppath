    <mxCell id="fe_cand_d" value="/chat — mentor chat window    /test — preliminary and advancement tests    /mock — interview simulation    /progress — channel, covered concepts, gaps, readiness score" style="text;html=1;fontSize=9;fontColor=#5B21B6;align=center;" vertex="1" parent="fe_bg">
