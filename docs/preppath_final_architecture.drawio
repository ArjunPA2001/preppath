      <mxGeometry x="20" y="36" width="240" height="80" as="geometry" />
    </mxCell>
    <mxCell id="db_pg_d" value="users · candidates★ · learning_paths&#xa;sections · eval_patterns · concepts&#xa;questions★ · rubrics · sessions★&#xa;session_answers · assessments&#xa;candidate_plans · candidate_question_history&#xa;★ = key tables for channel + gate + selection" style="text;html=1;fontSize=8;fontColor=#1E3A8A;align=center;" vertex="1" parent="db_bg">
      <mxGeometry x="20" y="120" width="240" height="40" as="geometry" />
    </mxCell>

    <!-- key columns callout -->
