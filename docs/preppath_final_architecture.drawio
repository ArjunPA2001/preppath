    <!-- Executive view -->
    <mxCell id="fe_exec" value="Executive View  /dashboard" style="rounded=1;fillColor=#DDD6FE;strokeColor=#7C3AED;fontColor=#4C1D95;fontSize=10;fontStyle=1;" vertex="1" parent="fe_bg">
      <mxGeometry x="20" y="38" width="300" height="38" as="geometry" />
