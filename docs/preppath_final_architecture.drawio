      <mxGeometry x="280" y="36" width="480" height="30" as="geometry" />
    </mxCell>
    <mxCell id="db_cols_d" value="candidates:  channel · level · gaps[] · strengths[] · pre_improvement_channel · interview_ready · plan_id&#xa;questions:   concept_tag · difficulty_band · seniority · pattern_type · is_preliminary · status&#xa;sessions:    covered_concepts[] · required_concepts[] · answer_count · current_concept_tag&#xa;cand_q_hist: candidate_id · question_id · last_quality · times_seen" style="text;html=1;fontSize=8;fontColor=#1E3A8A;align=left;" vertex="1" parent="db_bg">
      <mxGeometry x="280" y="70" width="480" height="90" as="geometry" />
    </mxCell>

    <!-- In-memory -->
    <mxCell id="db_mem" value="In-process Python dict{}" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fillColor=#BFDBFE;strokeColor=#2563EB;fontColor=#1E3A8A;fontSize=10;fontStyle=1;" vertex="1" parent="db_bg">
