    </mxCell>
    <mxCell id="db_mem_d" value="session_id → last 6 chat turns&#xa;session_id → session_question_ids set&#xa;(lives in FastAPI app memory)" style="text;html=1;fontSize=8;fontColor=#1E3A8A;align=center;" vertex="1" parent="db_bg">
