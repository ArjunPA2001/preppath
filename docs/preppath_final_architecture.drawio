    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- CANDIDATE JOURNEY (right side annotation) -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <mxCell id="journey_bg" value="Candidate Journey (what happens step by step)" style="swimlane;startSize=26;fillColor=#F9FAFB;strokeColor=#6B7280;fontColor=#374151;fontSize=10;fontStyle=1;rounded=1;" vertex="1" parent="1">
      <mxGeometry x="1614" y="148" width="240" height="830" as="geometry" />
    </mxCell>

    <mxCell id="j1" value="1. Feeder assigns learning path" style="rounded=1;fillColor=#E0E7FF;strokeColor=#6366F1;fontColor=#3730A3;fontSize=9;" vertex="1" parent="journey_bg">
      <mxGeometry x="10" y="30" width="220" height="30" as="geometry" />
    </mxCell>
    <mxCell id="j2" value="2. Preliminary test auto-built&#xa;(1 question per concept, no LLM)" style="rounded=1;fillColor=#E0E7FF;strokeColor=#6366F1;fontColor=#3730A3;fontSize=9;" vertex="1" parent="journey_bg">
      <mxGeometry x="10" y="72" width="220" height="36" as="geometry" />
    </mxCell>
    <mxCell id="j3" value="3. Candidate takes preliminary test" style="rounded=1;fillColor=#E0E7FF;strokeColor=#6366F1;fontColor=#3730A3;fontSize=9;" vertex="1" parent="journey_bg">
      <mxGeometry x="10" y="120" width="220" height="30" as="geometry" />
    </mxCell>
    <mxCell id="j4" value="4. Evaluator Agent runs&#xa;→ sets level, channel, gaps, strengths" style="rounded=1;fillColor=#FED7AA;strokeColor=#EA580C;fontColor=#7C2D12;fontSize=9;" vertex="1" parent="journey_bg">
      <mxGeometry x="10" y="162" width="220" height="36" as="geometry" />
    </mxCell>
    <mxCell id="j5" value="5. Plan Gen Agent runs&#xa;→ creates personalised session plan" style="rounded=1;fillColor=#FED7AA;strokeColor=#EA580C;fontColor=#7C2D12;fontSize=9;" vertex="1" parent="journey_bg">
      <mxGeometry x="10" y="210" width="220" height="36" as="geometry" />
    </mxCell>
    <mxCell id="j6" value="6. Candidate chats with Mentor&#xa;Mentor reads plan + channel + gaps" style="rounded=1;fillColor=#BBF7D0;strokeColor=#16A34A;fontColor=#14532D;fontSize=9;" vertex="1" parent="journey_bg">
      <mxGeometry x="10" y="258" width="220" height="36" as="geometry" />
    </mxCell>
    <mxCell id="j7" value="7. Each answered question:&#xa;topic gate updated · band selected&#xa;question_history updated" style="rounded=1;fillColor=#F3F4F6;strokeColor=#6B7280;fontColor=#374151;fontSize=9;" vertex="1" parent="journey_bg">
      <mxGeometry x="10" y="306" width="220" height="46" as="geometry" />
    </mxCell>
    <mxCell id="j8" value="8. When all concepts covered&#xa;topic gate fires →&#xa;Evaluator Agent runs" style="rounded=1;fillColor=#FED7AA;strokeColor=#EA580C;fontColor=#7C2D12;fontSize=9;" vertex="1" parent="journey_bg">
      <mxGeometry x="10" y="364" width="220" height="46" as="geometry" />
    </mxCell>
    <mxCell id="j9" value="9a. Scores met → advance channel&#xa;9b. Scores not met → stay + improve&#xa;9c. Regressed → drop channel" style="rounded=1;fillColor=#FEF3C7;strokeColor=#D97706;fontColor=#78350F;fontSize=9;" vertex="1" parent="journey_bg">
      <mxGeometry x="10" y="422" width="220" height="46" as="geometry" />
    </mxCell>
    <mxCell id="j10" value="10. Repeat steps 6-9 per section&#xa;until all sections complete" style="rounded=1;fillColor=#BBF7D0;strokeColor=#16A34A;fontColor=#14532D;fontSize=9;" vertex="1" parent="journey_bg">
      <mxGeometry x="10" y="480" width="220" height="36" as="geometry" />
    </mxCell>
    <mxCell id="j11" value="11. Simulation channel complete&#xa;→ interview_ready = True&#xa;→ visible on Executive Dashboard" style="rounded=1;fillColor=#DDD6FE;strokeColor=#7C3AED;fontColor=#4C1D95;fontSize=9;" vertex="1" parent="journey_bg">
      <mxGeometry x="10" y="528" width="220" height="46" as="geometry" />
    </mxCell>

