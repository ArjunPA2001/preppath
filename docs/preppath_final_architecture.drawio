    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- ROW 3 — BACKEND (FastAPI routers) -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <mxCell id="be_bg" value="Backend — FastAPI  (single process, 5 routers)" style="swimlane;startSize=28;fillColor=#F0FDF4;strokeColor=#16A34A;fontColor=#14532D;fontSize=11;fontStyle=1;rounded=1;" vertex="1" parent="1">
      <mxGeometry x="60" y="318" width="1540" height="210" as="geometry" />
    </mxCell>

    <!-- router: candidates -->
    <mxCell id="rt_cand" value="router/candidate.py" style="rounded=1;fillColor=#BBF7D0;strokeColor=#16A34A;fontColor=#14532D;fontSize=10;fontStyle=1;" vertex="1" parent="be_bg">
      <mxGeometry x="20" y="38" width="220" height="36" as="geometry" />
    </mxCell>
    <mxCell id="rt_cand_d" value="POST   /candidates&#xa;GET    /candidates/{id}&#xa;PUT    /candidates/{id}/pipeline&#xa;GET    /candidates/{id}/progress&#xa;&#xa;On PUT pipeline → auto-build preliminary test&#xa;                → trigger Plan Gen Agent" style="text;html=1;fontSize=8;fontColor=#14532D;align=left;" vertex="1" parent="be_bg">
      <mxGeometry x="20" y="78" width="220" height="96" as="geometry" />
    </mxCell>

    <!-- router: pipeline -->
    <mxCell id="rt_pipe" value="router/pipeline.py" style="rounded=1;fillColor=#BBF7D0;strokeColor=#16A34A;fontColor=#14532D;fontSize=10;fontStyle=1;" vertex="1" parent="be_bg">
      <mxGeometry x="260" y="38" width="220" height="36" as="geometry" />
    </mxCell>
    <mxCell id="rt_pipe_d" value="POST   /pipelines&#xa;PUT    /pipelines/{id}&#xa;POST   /pipelines/{id}/sections&#xa;POST   /pipelines/{id}/publish&#xa;&#xa;On publish → trigger Question Gen Agent&#xa;           → trigger Rubric Gen (same run)" style="text;html=1;fontSize=8;fontColor=#14532D;align=left;" vertex="1" parent="be_bg">
      <mxGeometry x="260" y="78" width="220" height="96" as="geometry" />
    </mxCell>

    <!-- router: session (STAR) -->
    <mxCell id="rt_sess" value="router/session.py  ★  (orchestrator)" style="rounded=1;fillColor=#86EFAC;strokeColor=#16A34A;fontColor=#14532D;fontSize=10;fontStyle=1;strokeWidth=2;" vertex="1" parent="be_bg">
      <mxGeometry x="500" y="38" width="320" height="36" as="geometry" />
    </mxCell>
    <mxCell id="rt_sess_d" value="POST   /sessions&#xa;POST   /sessions/{id}/chat  ← main chat turn&#xa;GET    /sessions/{id}/gate-status&#xa;POST   /sessions/{id}/end&#xa;&#xa;Each chat turn:&#xa;  1. call Mentor Agent (stream response)&#xa;  2. parse signal tag → concept_tag + quality&#xa;  3. write session_answers row&#xa;  4. call record_answer_topic() → update covered_concepts&#xa;  5. call check_topic_gate() → gate ready?&#xa;  6. if gate fires → call Evaluator Agent → update channel" style="text;html=1;fontSize=8;fontColor=#14532D;align=left;" vertex="1" parent="be_bg">
      <mxGeometry x="500" y="78" width="320" height="114" as="geometry" />
    </mxCell>

    <!-- router: assessment -->
    <mxCell id="rt_assess" value="router/assessment.py" style="rounded=1;fillColor=#BBF7D0;strokeColor=#16A34A;fontColor=#14532D;fontSize=10;fontStyle=1;" vertex="1" parent="be_bg">
      <mxGeometry x="840" y="38" width="260" height="36" as="geometry" />
    </mxCell>
    <mxCell id="rt_assess_d" value="POST   /assessments           ← create test&#xa;POST   /assessments/{id}/submit ← candidate done&#xa;GET    /assessments/{id}/result&#xa;&#xa;On submit → call Evaluator Agent&#xa;  returns: level + channel + gaps + strengths&#xa;  router writes result to candidates table" style="text;html=1;fontSize=8;fontColor=#14532D;align=left;" vertex="1" parent="be_bg">
      <mxGeometry x="840" y="78" width="260" height="96" as="geometry" />
    </mxCell>

    <!-- router: questions -->
    <mxCell id="rt_q" value="router/questions.py" style="rounded=1;fillColor=#BBF7D0;strokeColor=#16A34A;fontColor=#14532D;fontSize=10;fontStyle=1;" vertex="1" parent="be_bg">
      <mxGeometry x="1120" y="38" width="260" height="36" as="geometry" />
    </mxCell>
    <mxCell id="rt_q_d" value="POST   /questions/generate&#xa;GET    /questions?concept=&amp;band=&amp;type=&#xa;&#xa;On generate → call Question Gen Agent&#xa;  creates 9 variants per seed&#xa;  (3 bands × 3 question types)&#xa;  each question tagged with:&#xa;  concept_tag · difficulty_band · seniority" style="text;html=1;fontSize=8;fontColor=#14532D;align=left;" vertex="1" parent="be_bg">
      <mxGeometry x="1120" y="78" width="260" height="96" as="geometry" />
    </mxCell>

    <!-- middleware bar -->
    <mxCell id="be_mid" value="Shared middleware: JWT auth  ·  role guard (executive / feeder / candidate)  ·  CORS" style="rounded=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontColor=#14532D;fontSize=9;align=center;" vertex="1" parent="be_bg">
      <mxGeometry x="20" y="184" width="1500" height="20" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- ROW 4 — CORE LOGIC (no LLM — pure Python) -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <mxCell id="logic_bg" value="Core Logic — plain Python, no LLM calls" style="swimlane;startSize=28;fillColor=#F8FAFC;strokeColor=#6B7280;fontColor=#374151;fontSize=11;fontStyle=1;rounded=1;" vertex="1" parent="1">
      <mxGeometry x="60" y="568" width="1540" height="150" as="geometry" />
    </mxCell>

    <!-- topic gate -->
    <mxCell id="lg_gate" value="core/topic_gate.py" style="rounded=1;fillColor=#F3F4F6;strokeColor=#6B7280;fontColor=#374151;fontSize=10;fontStyle=1;" vertex="1" parent="logic_bg">
      <mxGeometry x="20" y="38" width="460" height="36" as="geometry" />
    </mxCell>
    <mxCell id="lg_gate_d" value="record_answer_topic(session_id, concept_tag)&#xa;  → appends concept to session.covered_concepts, increments answer_count&#xa;&#xa;check_topic_gate(session_id) → GateResult&#xa;  → if answer_count ≥ 3 AND covered_concepts ⊇ required_concepts → should_fire = True&#xa;  → called by session router after EVERY answered question&#xa;  → ALSO used by Improvement channel: required_concepts = gap concepts only" style="text;html=1;fontSize=8;fontColor=#374151;align=left;" vertex="1" parent="logic_bg">
      <mxGeometry x="20" y="78" width="460" height="60" as="geometry" />
    </mxCell>

    <!-- question selector -->
    <mxCell id="lg_qsel" value="core/question_selector.py" style="rounded=1;fillColor=#F3F4F6;strokeColor=#6B7280;fontColor=#374151;fontSize=10;fontStyle=1;" vertex="1" parent="logic_bg">
      <mxGeometry x="500" y="38" width="500" height="36" as="geometry" />
    </mxCell>
    <mxCell id="lg_qsel_d" value="select_band(channel, attempt_count, last_quality) → band string&#xa;  attempt 1 or absent → one band below channel ceiling    ·    wrong/partial → foundational    ·    correct 2nd+ → ceiling band&#xa;&#xa;fetch_question(candidate_id, concept_tag, band, seniority, pattern_type, session_ids) → Question&#xa;  Layer 1: exclude session_question_ids (in-memory set)    ·    Layer 2: exclude questions last_quality=correct (1 DB read)&#xa;  Fallback A: drop history filter if pool empty    ·    Fallback B: return None → mentor asks freeform" style="text;html=1;fontSize=8;fontColor=#374151;align=left;" vertex="1" parent="logic_bg">
      <mxGeometry x="500" y="78" width="500" height="60" as="geometry" />
    </mxCell>

    <!-- preliminary test builder -->
    <mxCell id="lg_prelim" value="core/preliminary_test.py" style="rounded=1;fillColor=#F3F4F6;strokeColor=#6B7280;fontColor=#374151;fontSize=10;fontStyle=1;" vertex="1" parent="logic_bg">
      <mxGeometry x="1020" y="38" width="500" height="36" as="geometry" />
    </mxCell>
    <mxCell id="lg_prelim_d" value="build_preliminary_test(section_id) → list of Questions&#xa;  Deterministic — no LLM. Queries one is_preliminary=True question per concept_tag in the section&#xa;  Falls back to one foundational-band question per concept if no seed is marked preliminary&#xa;  Called by router/candidate.py when Feeder assigns a learning path to a candidate" style="text;html=1;fontSize=8;fontColor=#374151;align=left;" vertex="1" parent="logic_bg">
      <mxGeometry x="1020" y="78" width="500" height="60" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- ROW 5 — AI AGENTS -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <mxCell id="ag_bg" value="AI Agents — 4 agents, called inline from routers" style="swimlane;startSize=28;fillColor=#FFF7ED;strokeColor=#EA580C;fontColor=#7C2D12;fontSize=11;fontStyle=1;rounded=1;" vertex="1" parent="1">
      <mxGeometry x="60" y="758" width="1540" height="250" as="geometry" />
    </mxCell>

    <!-- Mentor Agent -->
    <mxCell id="ag_mentor" value="Mentor Agent  agents/mentor.py" style="rounded=1;fillColor=#FED7AA;strokeColor=#EA580C;fontColor=#7C2D12;fontSize=10;fontStyle=1;" vertex="1" parent="ag_bg">
      <mxGeometry x="20" y="38" width="360" height="36" as="geometry" />
    </mxCell>
    <mxCell id="ag_mentor_d" value="Model: claude-sonnet-4-6  (streaming)&#xa;Called by: router/session.py on every chat turn&#xa;&#xa;Reads each turn: channel · gaps · strengths · candidate plan&#xa;  section description · eval pattern description · covered_concepts&#xa;  required_concepts (so it can bias toward uncovered topics)&#xa;&#xa;technique_selector(quality, attempt_count, channel) picks from 8 techniques&#xa;  → builds system prompt with channel persona + technique instruction&#xa;  → appends hidden &lt;signal&gt;{concept_tag, quality}&lt;/signal&gt; to every response&#xa;&#xa;Output: streamed text (signal tag stripped before client sees it)&#xa;Signal tag parsed by session router to feed topic gate and question selector&#xa;&#xa;Does NOT plan sessions. Does NOT trigger assessments. Executes only." style="text;html=1;fontSize=8;fontColor=#7C2D12;align=left;fillColor=#FFEDD5;strokeColor=#FED7AA;rounded=1;" vertex="1" parent="ag_bg">
      <mxGeometry x="20" y="78" width="360" height="160" as="geometry" />
    </mxCell>

    <!-- Evaluator Agent -->
    <mxCell id="ag_eval" value="Evaluator Agent  agents/evaluator.py" style="rounded=1;fillColor=#FED7AA;strokeColor=#EA580C;fontColor=#7C2D12;fontSize=10;fontStyle=1;" vertex="1" parent="ag_bg">
      <mxGeometry x="400" y="38" width="360" height="36" as="geometry" />
    </mxCell>
    <mxCell id="ag_eval_d" value="Model: claude-haiku-4-5  (fast, non-streaming)&#xa;Called by: router/assessment.py AND router/session.py (when gate fires)&#xa;&#xa;SAME agent handles ALL 3 triggers — only the input changes:&#xa;  trigger=preliminary_test  → raw test answers → sets first channel&#xa;  trigger=topic_gate        → session answers  → advances or stays&#xa;  trigger=mock_interview    → full mock transcript → section complete?&#xa;&#xa;Receives: answers[] + rubric (generated at publish time) + seniority&#xa;Returns strict JSON:&#xa;  { level, channel, gaps[], strengths[], scores{accuracy,fluency,depth}, feedback }&#xa;&#xa;★ Channel assignment ONLY happens here. Nowhere else in the system.&#xa;  Router writes channel + gaps + strengths + level back to candidates table." style="text;html=1;fontSize=8;fontColor=#7C2D12;align=left;fillColor=#FFEDD5;strokeColor=#FED7AA;rounded=1;" vertex="1" parent="ag_bg">
      <mxGeometry x="400" y="78" width="360" height="160" as="geometry" />
    </mxCell>

    <!-- Question Gen Agent -->
    <mxCell id="ag_qgen" value="Question Gen Agent  agents/question_gen.py" style="rounded=1;fillColor=#FED7AA;strokeColor=#EA580C;fontColor=#7C2D12;fontSize=10;fontStyle=1;" vertex="1" parent="ag_bg">
      <mxGeometry x="780" y="38" width="360" height="36" as="geometry" />
    </mxCell>
    <mxCell id="ag_qgen_d" value="Model: claude-sonnet-4-6  (non-streaming)&#xa;Called by: router/questions.py when Feeder publishes a learning path&#xa;Also generates rubrics in the same run (no separate agent needed)&#xa;&#xa;Receives: seed questions · concept list · seniority · section · pattern descriptions&#xa;&#xa;For EACH seed question generates 9 variants:&#xa;  3 difficulty bands × 3 question types&#xa;  bands:  foundational · deepdive · interview_ready&#xa;  types:  conceptual · scenario · problem_solving&#xa;&#xa;Each generated question is stored with:&#xa;  concept_tag  (matches section concept list — used by topic gate)&#xa;  difficulty_band  (used by question selector)&#xa;  seniority    (relative to learning path — junior/mid/senior)&#xa;  is_preliminary flag (one per concept for cold-start test)" style="text;html=1;fontSize=8;fontColor=#7C2D12;align=left;fillColor=#FFEDD5;strokeColor=#FED7AA;rounded=1;" vertex="1" parent="ag_bg">
      <mxGeometry x="780" y="78" width="360" height="160" as="geometry" />
    </mxCell>

    <!-- Plan Gen Agent -->
    <mxCell id="ag_plan" value="Plan Gen Agent  agents/plan_gen.py" style="rounded=1;fillColor=#FED7AA;strokeColor=#EA580C;fontColor=#7C2D12;fontSize=10;fontStyle=1;" vertex="1" parent="ag_bg">
      <mxGeometry x="1160" y="38" width="360" height="36" as="geometry" />
    </mxCell>
    <mxCell id="ag_plan_d" value="Model: claude-sonnet-4-6  (non-streaming)&#xa;Called by: router/candidate.py ONCE when learning path assigned&#xa;Runs AFTER preliminary test results are available&#xa;&#xa;Receives: preliminary test result (level, gaps, strengths)&#xa;  full learning path (sections, concepts, eval patterns, seniority)&#xa;&#xa;Generates a personalised candidate_plan:&#xa;  section_order[]     which sections in what sequence&#xa;  concept_weights{}   which concepts to emphasise more&#xa;  pattern_weights{}   which eval patterns to use more&#xa;  difficulty_start{}  starting band per concept&#xa;&#xa;Stored once. Mentor Agent reads this plan on every chat turn.&#xa;Plan can be updated by Evaluator Agent if channel changes significantly." style="text;html=1;fontSize=8;fontColor=#7C2D12;align=left;fillColor=#FFEDD5;strokeColor=#FED7AA;rounded=1;" vertex="1" parent="ag_bg">
      <mxGeometry x="1160" y="78" width="360" height="160" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- ROW 6 — CHANNEL STATE -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <mxCell id="ch_bg" value="Channel State — stored as candidate.channel in DB, read by Mentor Agent each turn, written ONLY by Evaluator Agent" style="swimlane;startSize=28;fillColor=#FFFBEB;strokeColor=#D97706;fontColor=#78350F;fontSize=11;fontStyle=1;rounded=1;" vertex="1" parent="1">
      <mxGeometry x="60" y="1048" width="1540" height="120" as="geometry" />
    </mxCell>

    <mxCell id="ch1" value="foundation&#xa;accuracy ≥ 60 · fluency ≥ 50" style="rounded=1;fillColor=#FEF3C7;strokeColor=#D97706;fontColor=#78350F;fontSize=10;fontStyle=1;" vertex="1" parent="ch_bg">
      <mxGeometry x="20" y="38" width="330" height="60" as="geometry" />
    </mxCell>
    <mxCell id="ch1_d" value="Teach before test · scaffold + analogy · no time pressure · Goal: concept coverage at basic correctness" style="text;html=1;fontSize=8;fontColor=#78350F;align=center;" vertex="1" parent="ch_bg">
      <mxGeometry x="20" y="82" width="330" height="28" as="geometry" />
    </mxCell>

    <mxCell id="ch2" value="deepdive&#xa;accuracy ≥ 75 · depth ≥ 65 · fluency ≥ 65" style="rounded=1;fillColor=#FEF3C7;strokeColor=#D97706;fontColor=#78350F;fontSize=10;fontStyle=1;" vertex="1" parent="ch_bg">
      <mxGeometry x="380" y="38" width="350" height="60" as="geometry" />
    </mxCell>
    <mxCell id="ch2_d" value="Challenge + Socratic + constraint injection · Goal: trade-off reasoning and edge-case awareness" style="text;html=1;fontSize=8;fontColor=#78350F;align=center;" vertex="1" parent="ch_bg">
      <mxGeometry x="380" y="82" width="350" height="28" as="geometry" />
    </mxCell>

    <mxCell id="ch3" value="simulation&#xa;accuracy ≥ 85 · depth ≥ 80 · fluency ≥ 75" style="rounded=1;fillColor=#FEF3C7;strokeColor=#D97706;fontColor=#78350F;fontSize=10;fontStyle=1;" vertex="1" parent="ch_bg">
      <mxGeometry x="760" y="38" width="380" height="60" as="geometry" />
    </mxCell>
    <mxCell id="ch3_d" value="Mentor = interviewer · no hints · time pressure · debrief only · Goal: interview performance · interview_ready flag set on completion" style="text;html=1;fontSize=8;fontColor=#78350F;align=center;" vertex="1" parent="ch_bg">
      <mxGeometry x="760" y="82" width="380" height="28" as="geometry" />
    </mxCell>

    <mxCell id="ch4" value="improvement  (detour — not a progression step)" style="rounded=1;fillColor=#FEF3C7;strokeColor=#D97706;fontColor=#78350F;fontSize=10;fontStyle=1;" vertex="1" parent="ch_bg">
      <mxGeometry x="1170" y="38" width="350" height="60" as="geometry" />
    </mxCell>
    <mxCell id="ch4_d" value="Triggered from ANY channel when critical gap found · saves pre_improvement_channel · topic gate targets gap concepts only · returns to saved channel when gaps closed" style="text;html=1;fontSize=8;fontColor=#78350F;align=center;" vertex="1" parent="ch_bg">
      <mxGeometry x="1170" y="82" width="350" height="28" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- ROW 7 — DATA LAYER -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
